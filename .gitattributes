# Git LFS (Large File Storage) — Versionamento de arquivos grandes

# CSVs processados — versionados com git-lfs
exports/csv/*.csv filter=lfs diff=lfs merge=lfs -text

# PNGs de gráficos — não crítico, mas opcional para LFS se crescer muito
exports/figs/*.png filter=lfs diff=lfs merge=lfs -text

# Arquivos de dados brutos (XLSX, XLS) — opcional, ocupam espaço
exports/hojas/extrato/*.xls filter=lfs diff=lfs merge=lfs -text
exports/hojas/prestacao/*.xlsx filter=lfs diff=lfs merge=lfs -text

# PDFs — ocupam espaço, usar LFS
exports/pdf/*.pdf filter=lfs diff=lfs merge=lfs -text

# Configuração: sempre usar diff textual para CSVs quando possível
*.csv diff=csv
